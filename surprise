<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>🦖 Secret Page</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="css/navbar.css">
  <link rel="stylesheet" href="css/footer.css">
  <link rel="stylesheet" href="css/cart.css">
  <link rel="stylesheet" href="css/dino.css">
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f7f7f7;
      font-family: 'Quicksand', sans-serif;
    }
    .secret-header {
      text-align: center;
      padding: 60px 20px 10px;
    }
    .secret-header h1 {
      font-size: 1.8rem;
      margin: 0 0 8px;
      letter-spacing: 2px;
    }
    .secret-header p {
      font-size: 0.95rem;
      color: #555;
      margin: 0;
    }
    .game-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px 20px 60px;
    }
    /* Force the canvas area to be visible */
    .interstitial-wrapper {
      width: 600px;
      max-width: 90vw;
    }
  </style>
  <script>
    /* Prevent spacebar from scrolling */
    document.documentElement.addEventListener("keydown", function(e) {
      (e.keyCode || e.which) == 32 && e.preventDefault();
    }, false);

    /* Disable sound loading entirely by patching it out */
    window.addEventListener("load", function() {
      if (window.Runner && Runner.instance_) {
        Runner.instance_.loadSounds = function() {};
      }
    });
	   window.devicePixelRatio = 1;
  </script>
</head>

<body class="offline main-page" id="t">

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="index.html"><img src="images/mozartlaserlogo.png" alt="MozartLaser" class="logo"></a>
      <nav class="main-nav">
        <ul>
          <li><a href="index.html">Home</a></li>
          <li><a href="products.html">Products</a></li>
          <li><a href="create.html">Create</a></li>
			 <li><a href="blog.html">Blog</a></li>
          <li><a href="About.html">About</a></li>
        </ul>
      </nav>
      <div class="hamburger"><span></span><span></span><span></span></div>
    </div>
    <div class="cart-icon" id="cart-icon">
      <img src="images/cart-icon.png" alt="Cart">
      <span id="cart-count">0</span>
    </div>
  </header>

  <!-- CART PANEL -->
  <div class="cart-panel" id="cart-panel">
    <h3>Shopping Cart</h3>
    <ul id="cart-items"></ul>
    <p>Total: $<span id="cart-total">0.00</span></p>
    <button id="checkout">Checkout</button>
    <button id="close-cart">Close</button>
  </div>

  <!-- SECRET  -->
  <div class="secret-header">
    <h1>🦖 You found the secret!</h1>
    <p>Press <strong>Space</strong> to start &nbsp;·&nbsp; <strong>↓</strong> to duck &nbsp;·&nbsp; <strong>↑</strong> to jump</p>
  </div>

  <div class="game-wrapper">
    <div class="interstitial-wrapper">
      <div id="main-content"></div>
    </div>
  </div>

  <section id="offline-resources" style="display:none;">
    <img alt="Dino, sprite 1" id="offline-resources-1x" src="images/sprite-1x.png">
    <img alt="Dino, sprite 2" id="offline-resources-2x" src="images/sprite-2x.png">
    <template id="audio-resources"></template>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-content">
      <div class="social-links">
        <a href="https://www.facebook.com/profile.php?id=61585614995027" target="_blank" aria-label="Facebook"><img src="images/facebook-icon.png" alt="Facebook"></a>
        <a href="https://instagram.com/mozartlaser" target="_blank" aria-label="Instagram"><img src="images/instagram-icon.png" alt="Instagram"></a>
        <a href="https://X.com/mozartlaser" target="_blank" aria-label="X"><img src="images/X-icon.png" alt="X"></a>
      </div>
      <p>&copy; 2026 Mozart Laser. All rights reserved.</p>
    </div>
  </footer>

  <script src="js/navbar.js"></script>
  <script src="js/cart.js"></script>
  <!-- Patch loadSounds before dino.js runs -->
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      var originalRunner = window.Runner;
      if (originalRunner && originalRunner.prototype) {
        originalRunner.prototype.loadSounds = function() {};
      }
    });
  </script>
  <script src="js/dino.js"></script>

</body>
</html>
